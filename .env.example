# Copy this file to .env and fill in your values
# Do not commit .env to version control

# Open States / Plural Policy API (for legislator lookup by address)
OPEN_STATES_API_KEY=your_open_states_api_key

# EmailJS (for sending advocacy emails)
EMAILJS_PUBLIC_KEY=your_emailjs_public_key
EMAILJS_SERVICE_ID=your_service_id
EMAILJS_TEMPLATE_ID=your_template_id

# Supabase (for admin panel / send logging)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
# ADMIN_SECRET: set via "supabase secrets set ADMIN_SECRET=..." — not in .env
