# Copy this file to .env and fill in your values
# Do not commit .env to version control

# Google Civic Information API (for address/legislator lookup - Divisions API)
GOOGLE_CIVIC_KEY=your_google_civic_api_key

# Open States / Plural Policy API (for legislator details by district)
OPEN_STATES_API_KEY=your_open_states_api_key

# EmailJS (for sending advocacy emails)
EMAILJS_PUBLIC_KEY=your_emailjs_public_key
EMAILJS_SERVICE_ID=your_service_id
EMAILJS_TEMPLATE_ID=your_template_id
